# Rootbugs Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgres://rootbugs:rootbugs_dev@localhost:5432/rootbugs

# OpenAI (required for Brain LLM and Graph NLP)
OPENAI_API_KEY=sk-...

# GitHub (optional, for Graph crawler)
GITHUB_TOKEN=ghp_...

# Service Ports
BRAIN_CORE_PORT=4001
BRAIN_LLM_PORT=4002
BRAIN_DASHBOARD_PORT=3001
PREDICT_GIT_PORT=4003
PREDICT_CORE_PORT=4004
PREDICT_DASHBOARD_PORT=3002
GRAPH_CRAWLER_PORT=4005
GRAPH_NLP_PORT=4006
GRAPH_API_PORT=4007
GRAPH_FRONTEND_PORT=3003

# Rust log level
RUST_LOG=info

# Node environment
NODE_ENV=development
